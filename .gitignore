# ══════════════════════════════════════════════════════════════════════════════
#  Hotpulse — .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
build/
.eggs/

# ── Sanal ortam ───────────────────────────────────────────────────────────────
venv/
env/
.venv/
.pythonlibs/

# ── Ortam değişkenleri ────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Node / pnpm ───────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/
dist/
*.tsbuildinfo

# ── Media dosyaları ───────────────────────────────────────────────────────────
# Şimdilik git'te takip ediliyor — ileride büyüyünce ignore eklenecek.

# ── Derlenmiş static dosyalar ─────────────────────────────────────────────────
# Django admin ve RF static'leri collectstatic ile gelir, git'te tutulmaz.
backend/static/admin/
backend/static/rest_framework/
# Frontend build output (backend/static/assets/) Windows VDS için git'te tutulur.
# Bu satırı uncomment etme.

# ── Build / deploy artifact dosyaları ────────────────────────────────────────
backend/.migration_done
backend/.static_done
.migration_done
.static_done
.static_hash

# ── Duplike klasörler (hatalı tarball çıkarma sonucu oluşur) ─────────────────
# update.sh tarball'ı scripts/ veya repo kökü dışında çalıştırılırsa
# bu klasörler oluşabilir — git'e asla girmesin.
scripts/backend/
scripts/scripts/

# ── Backup arşivleri ──────────────────────────────────────────────────────────
scripts/backups/*.tar.gz
scripts/backups/*.json
backups/

# ── Log ve paste dosyaları ────────────────────────────────────────────────────
attached_assets/
*.log
logs/

# ── IDE ve OS ─────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Replit iç dosyaları ───────────────────────────────────────────────────────
.agents/memory/
.local/
.cache/

# ── Veritabanı ────────────────────────────────────────────────────────────────
# db.sqlite3 intentionally tracked — dev ortamı için ortak DB.
# Üretimde PostgreSQL kullanılır (DATABASE_URL env var).
