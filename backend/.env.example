# Hotpulse Backend — Django Ortam Değişkenleri
# Kullanım: copy .env.example .env   (sonra .env'i düzenle)
# SECRET_KEY üretmek için:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"

# ── Güvenlik ─────────────────────────────────────────────────────────────────
SECRET_KEY=your-very-secret-key-change-this-in-production

# Üretimde mutlaka False
DEBUG=False

# ── Domain ───────────────────────────────────────────────────────────────────
ALLOWED_HOSTS=hotpulse.me,www.hotpulse.me,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://hotpulse.me,https://www.hotpulse.me
CORS_ALLOWED_ORIGINS=https://hotpulse.me,https://www.hotpulse.me
SITE_URL=https://hotpulse.me

# ── Veritabanı ────────────────────────────────────────────────────────────────
# PostgreSQL (üretim için önerilen):
DATABASE_URL=postgresql://hotpulse:SIFRENIZ@localhost:5432/hotpulse

# SQLite (sadece geliştirme):
# DATABASE_URL=sqlite:///db.sqlite3

# ── Medya dosyaları ───────────────────────────────────────────────────────────
MEDIA_URL=/media/
# MEDIA_ROOT=C:\hotpulse\backend\media   # Varsayılan: proje/media/

# ── E-posta (opsiyonel) ───────────────────────────────────────────────────────
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your@email.com
# EMAIL_HOST_PASSWORD=yourpassword
# DEFAULT_FROM_EMAIL=noreply@hotpulse.me

# ── Waitress / Port ───────────────────────────────────────────────────────────
# Nginx 127.0.0.1:8000'e bağlanır; dışarıya kapalı tut
PORT=8000
