# Hotpulse Backend — Django Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve doldurun:
#   cp .env.example .env && nano .env

# ── Güvenlik ─────────────────────────────────────────────────────────────────
# Şu komutla üretin:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-very-secret-key-change-this-in-production

# Üretimde mutlaka False yapın
DEBUG=False

# ── Domain ───────────────────────────────────────────────────────────────────
ALLOWED_HOSTS=hotpulse.me,www.hotpulse.me,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://hotpulse.me,https://www.hotpulse.me,http://localhost:8000
CORS_ALLOWED_ORIGINS=https://hotpulse.me,https://www.hotpulse.me,http://localhost:3000
SITE_URL=https://hotpulse.me

# ── Veritabanı ────────────────────────────────────────────────────────────────
# PostgreSQL (önerilen — 10k kullanıcı için zorunlu):
DATABASE_URL=postgresql://hotpulse:SIFRENIZ@localhost:5432/hotpulse

# SQLite (sadece geliştirme için, üretimde KULLANMAYIN):
# DATABASE_URL=sqlite:///db.sqlite3

# ── Medya dosyaları ───────────────────────────────────────────────────────────
MEDIA_URL=/media/
# MEDIA_ROOT=/var/www/hotpulse/media   # Varsayılan: backend/media/

# ── E-posta (opsiyonel) ───────────────────────────────────────────────────────
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your@email.com
# EMAIL_HOST_PASSWORD=yourpassword
# DEFAULT_FROM_EMAIL=noreply@hotpulse.me

# ── Port ──────────────────────────────────────────────────────────────────────
PORT=8000
