# Soci Backend — Django Environment Variables
  # Copy this file to .env and fill in your values

  # SECURITY — generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
  SECRET_KEY=your-very-secret-key-change-this-in-production

  # Set to False in production
  DEBUG=False

  # Your domain(s)
  ALLOWED_HOSTS=hotpulse.me,www.hotpulse.me,localhost,127.0.0.1

  # CSRF & CORS for your domain
  CSRF_TRUSTED_ORIGINS=https://hotpulse.me,https://www.hotpulse.me,http://localhost:8000
  CORS_ALLOWED_ORIGINS=https://hotpulse.me,https://www.hotpulse.me,http://localhost:3000

  # Database (SQLite for simple setup, or use PostgreSQL URL for production)
  DATABASE_URL=sqlite:///db.sqlite3
  # DATABASE_URL=postgresql://user:password@localhost:5432/soci

  # Media files
  MEDIA_URL=/media/

  # Email (optional)
  # EMAIL_HOST=smtp.gmail.com
  # EMAIL_PORT=587
  # EMAIL_HOST_USER=your@email.com
  # EMAIL_HOST_PASSWORD=yourpassword

  # Port Django runs on
  PORT=8000
  