# Bu dosyayı kopyala: cp .env.example backend/.env
# Aşağıdaki değerleri kendi sunucuna göre doldur

# ── Veritabanı ────────────────────────────────────────────────────────────────
# PostgreSQL bağlantı URL'i (önerilen)
DATABASE_URL=postgresql://kullanici:sifre@localhost:5432/hotpulse

# Veya ayrı ayrı:
# PGHOST=localhost
# PGPORT=5432
# PGUSER=hotpulse
# PGPASSWORD=sifre
# PGDATABASE=hotpulse

# ── Django ────────────────────────────────────────────────────────────────────
# Güvenli rastgele bir anahtar üret: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=buraya-uzun-rastgele-bir-deger-yaz

DEBUG=False

# Sitenin domain adı (virgülle ayır)
ALLOWED_HOSTS=hotpulse.me,www.hotpulse.me

# CSRF için (Cloudflare kullanıyorsan https olmalı)
CSRF_TRUSTED_ORIGINS=https://hotpulse.me,https://www.hotpulse.me

# ── Medya dosyaları ───────────────────────────────────────────────────────────
# Yüklenen videoların/resimlerin kaydedileceği klasör (tam yol)
MEDIA_ROOT=/var/www/hotpulse/media

# ── Opsiyonel ─────────────────────────────────────────────────────────────────
# Site URL (crosspost ve bildirimler için)
SITE_URL=https://hotpulse.me
