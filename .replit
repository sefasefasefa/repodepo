modules = ["nodejs-20", "python-3.11", "bash", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["freetype", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "tcl", "tk", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && python manage.py migrate --noinput && python manage.py collectstatic --noinput && gunicorn config.wsgi:application --config gunicorn.conf.py"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd backend && gunicorn config.wsgi:application --bind 0.0.0.0:8000 --workers 3 --timeout 120"]
build = ["bash", "-c", "cd backend && pip install -r requirements.txt && pnpm install && pnpm --filter @workspace/streamvid run build && cp -r artifacts/streamvid/dist/public/. static/ && python manage.py migrate --run-syncdb && python manage.py collectstatic --noinput"]

[userenv]

[userenv.shared]
DEBUG = "True"
SECRET_KEY = "dv#o+!knmn#g&$euhkb&r1g#r@=z1w_x4m%qg7520s8inrl8r5"
